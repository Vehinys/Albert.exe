        `\nWelcome. Type <span class="l-accent">help</span> for available commands.\nTip&nbsp;: <span class="kbd">Tab</span> for autocomplete, <span class="kbd">↑</span>/<span class="kbd">↓</span> for history.\n`,
      ),
      'l-info'
    );
  }

  // ── Sequence de boot ──────────────────────────────────────────────────
  function showBoot(): void {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const bootLines: Array<{ text: string; cls: string; delay: number }> = [
      { text: '[    0.000000] Linux version 6.1.0-albert SMP (gcc version 12.2.0)', cls: 'l-info', delay: 0 },
      { text: '[    0.156000] Command line: BOOT_IMAGE=/vmlinuz root=/dev/sda1 ro quiet', cls: 'l-info', delay: 130 },
      { text: '[  OK  ] Loading kernel modules...', cls: 'l-ok', delay: 300 },
      { text: '[  OK  ] Mounting /dev/sda1 (ext4)...', cls: 'l-ok', delay: 480 },
      { text: '[  OK  ] Starting network services...', cls: 'l-ok', delay: 640 },
      { text: '[  OK  ] SSH daemon started on port 22', cls: 'l-ok', delay: 780 },
      { text: '[  OK  ] Firewall (ufw) active.', cls: 'l-ok', delay: 890 },
      { text: '', cls: 'l-info', delay: 970 },
      { text: t('Welcome to albert-exe v2026 (Debian 13 "Trixie")', 'Welcome to albert-exe v2026 (Debian 13 "Trixie")'), cls: 'l-accent', delay: 1020 },
    ];

    if (reduced) {
      for (const line of bootLines) printLine(line.text, line.cls);
      showBanner();
      return;
    }

    for (const line of bootLines) {
      setTimeout(() => printLine(line.text, line.cls), line.delay);
