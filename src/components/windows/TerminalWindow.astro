      const rows: [string, string][] = [
        ['OS      ', 'albert-exe v2026 (Debian 13 "Trixie")'],
        ['Host    ', 'Portfolio -- Astro 5 + Tailwind v4'],
        ['Kernel  ', '6.1.0-albert SMP'],
        ['Uptime  ', t('7 ans experience web & design', '7 years web & design experience')],
        ['Shell   ', 'zsh 5.9 -- Mulhouse, FR'],
        ['CPU     ', t('Futur Admin AIS (GRETA Colmar 2026)', 'Future AIS Admin (GRETA Colmar 2026)')],
        ['RAM     ', t('Reconversion complete -- 100% operationnel', 'Full career switch -- 100% operational')],
        ['GPU     ', t('WordPress Expert + UI/UX Avance', 'WordPress Expert + Advanced UI/UX')],
        ['Infra   ', 'Linux · VMware · SSH · MariaDB · Docker'],
        ['Dev     ', 'Astro · TypeScript · Tailwind v4 · PHP'],
        ['Statut  ', t('Alternance AIS recherchee -- Haut-Rhin (68)', 'Seeking AIS apprenticeship -- Haut-Rhin (68)')],
      ];
      for (const [key, val] of rows) {
        const isStatut = key.includes('Statut');
        const cls = isStatut ? 'l-ok' : 'l-info';
        print(`<span class="${cls}">${escapeHtml(key)}:</span> ${escapeHtml(val)}`);
      }
    },

    fastfetch: () => commands['neofetch']!([]),

    ping: (args) => {
      const host = args[0];
      if (!host) return printLine(t('Usage : ping <host>', 'Usage: ping <host>'), 'l-err');

      const known: Record<string, { ip: string; note?: string }> = {
        'linkedin':  { ip: '108.174.10.10',  note: t('Profil a jour -- disponible (AIS)', 'Profile up to date -- available (AIS)') },
        'github':    { ip: '140.82.114.4',   note: t('Depot public visible', 'Public repo visible') },
        'vercel':    { ip: '76.76.21.21',    note: t('Portfolio en ligne', 'Portfolio online') },
        'google':    { ip: '142.250.74.46' },
        'localhost': { ip: '127.0.0.1' },
      };
      const info = known[host.toLowerCase()];
      const ip = info?.ip ?? '93.184.216.34';

      print(`<span class="l-info">PING ${escapeHtml(host)} (${ip}) 56(84) bytes of data.</span>`);
      for (let i = 1; i <= 3; i++) {
        const ms = 6 + Math.floor(Math.random() * 18);
        print(`<span class="l-ok">64 bytes from ${ip}: icmp_seq=${i} ttl=55 time=${ms} ms</span>`);
      }
      print(`<span class="l-info">--- ${escapeHtml(host)} ping statistics ---</span>`);
      print(`<span class="l-info">3 packets transmitted, 3 received, 0% packet loss</span>`);
      if (info?.note) {
        print(`<span class="l-accent">${escapeHtml(info.note)}</span>`);
      }
    },

    date: () => {
      const d = new Date();
      printLine(d.toLocaleString(lang === 'fr' ? 'fr-FR' : 'en-US', { dateStyle: 'full', timeStyle: 'medium' }));
    },

    echo: (args) => printLine(args.join(' ')),

    history: () => {
      if (history.length === 0) return printLine(t('(aucun)', '(empty)'), 'l-info');
      history.forEach((h, i) => print(`<span class="l-info">${String(i + 1).padStart(4)}</span>  ${escapeHtml(h)}`));
    },

    clear: () => clearOutput(),
    cls:   () => clearOutput(),

    projects: (args) => {
      const filterIdx = args.indexOf('--filter');
      const filter = filterIdx >= 0 ? args[filterIdx + 1] : undefined;
      if (!filter) {
        print(`<span class="l-ok">→</span> ${escapeHtml(t('Ouverture de la fenetre Projets...', 'Opening Projects window...'))}`);
        setTimeout(() => openWindow('projects'), 250);
        return;
      }
      print(`<span class="l-info">${escapeHtml(t(`Filtre actif : ${filter}`, `Active filter: ${filter}`))}</span>`);
      print(`<span class="l-ok">→</span> ${escapeHtml(t('Ouverture des projets filtres...', 'Opening filtered projects...'))}`);
      setTimeout(() => openWindow('projects'), 250);
    },

    skills:     () => { print(`<span class="l-ok">→</span> ${escapeHtml(t('Ouverture des competences...', 'Opening skills...'))}`); setTimeout(() => openWindow('skills'), 250); },
    experience: () => { print(`<span class="l-ok">→</span> ${escapeHtml(t('Ouverture du parcours...', 'Opening experience...'))}`); setTimeout(() => openWindow('experience'), 250); },
    contact:    () => { print(`<span class="l-ok">→</span> ${escapeHtml(t('Ouverture du formulaire...', 'Opening contact form...'))}`); setTimeout(() => openWindow('contact'), 250); },

    cv: () => {
      print(`<span class="l-ok">↓</span> ${escapeHtml(t('Telechargement du CV...', 'Downloading CV...'))}`);
      const a = document.createElement('a');
      a.href = '/cv/albert-lecomte-cv.pdf';
      a.download = 'albert-lecomte-cv.pdf';
      document.body.appendChild(a);
      a.click();
      a.remove();
    },

    hire: () => {
      print(`<span class="l-ok">●</span> <span class="l-ok">${escapeHtml(t('Statut : DISPONIBLE', 'Status: AVAILABLE'))}</span>`);
      print(`<span class="l-info">${escapeHtml(t('Formation AIS -- GRETA Colmar, rentree 2026', 'AIS Training -- GRETA Colmar, fall 2026'))}</span>`);
      print(`<span class="l-info">${escapeHtml(t('Profil : reconversion AIS, ex-designer UI, infra Linux/VMware', 'Profile: AIS career switch, former UI designer, Linux/VMware infra'))}</span>`);
      print(`<span class="l-info">${escapeHtml(t('Alternance recherchee dans le Haut-Rhin (68)', 'Seeking apprenticeship in Haut-Rhin (68)'))}</span>`);
      print(`<span class="l-info">${escapeHtml(t('Reponse sous 24h -- tape "contact" pour m\'ecrire.', 'Reply < 24h -- type "contact" to message me.'))}</span>`);
    },

    theme: (args) => {
      const t0 = args[0];
      if (!t0) return printLine(t('Usage : theme <dark|light>', 'Usage: theme <dark|light>'), 'l-err');
      if (t0 !== 'dark' && t0 !== 'light') return printLine(t(`Theme inconnu : ${t0}`, `Unknown theme: ${t0}`), 'l-err');
      document.documentElement.setAttribute('data-theme', t0);
      try { localStorage.setItem('theme', t0); } catch { /* ignore */ }
      print(`<span class="l-ok">✓</span> ${escapeHtml(t(`Theme ${t0} applique.`, `Theme ${t0} applied.`))}`);
    },

    quote: () => {
      mode = { kind: 'quote', step: 0, data: {} };
      print(`<span class="l-accent">+-- ${escapeHtml(t('Devis instantane', 'Instant quote'))} -----------------------------------------------+</span>`);
      print(`<span class="l-info">${escapeHtml(t('Tape "cancel" a tout moment pour annuler.', 'Type "cancel" anytime to cancel.'))}</span>`);
      askQuoteStep();
    },

    sudo: () => {
      print(`<span class="l-err">[sudo] ${escapeHtml(t('mot de passe pour albert :', 'password for albert:'))}</span>`);
      print(`<span class="l-warn">${escapeHtml(t('Permission refusee. Albert n\'est pas encore root -- mais il bosse l\'AIS 2026.', "Permission denied. Albert isn't root yet -- but he's working on it. AIS 2026."))}</span>`);
    },

    konami: () => {
      root!.classList.add('konami');
      setTimeout(() => root!.classList.remove('konami'), 600);
      print(`<span class="l-accent">${escapeHtml(t('↑ ↑ ↓ ↓ ← → ← → B A -- Code Konami active !', '↑ ↑ ↓ ↓ ← → ← → B A -- Konami code activated!'))}</span>`);
      print(`<span class="l-info">${escapeHtml(t('+99 vies. Bonne navigation.', '+99 lives. Have fun.'))}</span>`);
    },

    exit:  () => closeWindow('terminal'),
    close: () => closeWindow('terminal'),

    man: (args) => {
      const c = args[0];
      if (!c) return printLine(t('Quelle commande ?', 'Which command?'), 'l-err');
      if (!commands[c]) return printLine(t(`Aucune entree man pour ${c}`, `No manual entry for ${c}`), 'l-err');
      print(`<span class="l-accent">NAME</span>\n  ${escapeHtml(c)} -- ${escapeHtml(t('commande albert-exe', 'albert-exe command'))}\n\n<span class="l-accent">DESCRIPTION</span>\n  ${escapeHtml(t('Tape "help" pour la liste complete.', 'Type "help" for the full list.'))}\n`);
    },

    albert: () => commands['whoami']!([]),
  };

  // ── Quote flow ────────────────────────────────────────────────────────
  const QUOTE_QUESTIONS = [
    {
      q: t('Type de projet ? (vitrine / ecommerce / wordpress / refonte / app)', 'Project type? (showcase / ecommerce / wordpress / rework / app)'),
      validate: (v: string) => /^(vitrine|ecommerce|wordpress|wp|refonte|app|showcase|rework)$/i.test(v),
      assign: (data: any, v: string) => { data.type = v.toLowerCase(); },
    },
    {
      q: t('Nombre de pages ? (1-50)', 'Page count? (1-50)'),
      validate: (v: string) => /^\d+$/.test(v) && +v >= 1 && +v <= 50,
      assign: (data: any, v: string) => { data.pages = +v; },
    },
    {
      q: t('Multi-langue ? (oui/non)', 'Multi-language? (yes/no)'),
      validate: (v: string) => /^(oui|non|yes|no|y|n|o)$/i.test(v),
      assign: (data: any, v: string) => { data.multilang = /^(oui|yes|y|o)$/i.test(v); },
    },
    {
      q: t('Delai serre (< 4 semaines) ? (oui/non)', 'Rush (< 4 weeks)? (yes/no)'),
      validate: (v: string) => /^(oui|non|yes|no|y|n|o)$/i.test(v),
      assign: (data: any, v: string) => { data.rush = /^(oui|yes|y|o)$/i.test(v); },
    },
  ];

  function askQuoteStep(): void {
    if (mode.kind !== 'quote') return;
    const q = QUOTE_QUESTIONS[mode.step];
    if (!q) return finishQuote();
    print(`<span class="l-accent">[${mode.step + 1}/${QUOTE_QUESTIONS.length}]</span> <span class="l-info">${escapeHtml(q.q)}</span>`);
    prompt!.textContent = '?>';
  }

  function finishQuote(): void {
    if (mode.kind !== 'quote') return;
    const { type = '', pages = 1, multilang = false, rush = false } = mode.data;
    const base: Record<string, [number, number]> = {
      vitrine:   [1200, 2200],
      showcase:  [1200, 2200],
      wordpress: [1500, 3000],
      wp:        [1500, 3000],
      ecommerce: [3500, 7500],
      refonte:   [1800, 3500],
      rework:    [1800, 3500],
      app:       [4500, 9000],
    };
    const range = base[type] ?? [2000, 4000];
    const perPage = 150;
    const extraPages = Math.max(0, pages - 5);
    const langCoef = multilang ? 1.25 : 1;
    const rushCoef = rush ? 1.30 : 1;
    const min = Math.round(((range[0] ?? 0) + extraPages * perPage) * langCoef * rushCoef);
    const max = Math.round(((range[1] ?? 0) + extraPages * perPage * 1.5) * langCoef * rushCoef);
    const weeks = rush ? '3-4' : (pages <= 5 ? '4-6' : pages <= 15 ? '6-8' : '8-12');

    print(`<span class="l-accent">+--------------------------------------------------+</span>`);
    print('');
    print(`<span class="l-ok">${escapeHtml(t('✓ Estimation calculee', '✓ Quote calculated'))}</span>`);
    print('');
    print(`  <span class="l-info">${escapeHtml(t('Type        :', 'Type        :'))}</span> ${escapeHtml(type)}`);
    print(`  <span class="l-info">${escapeHtml(t('Pages       :', 'Pages       :'))}</span> ${pages}`);
    print(`  <span class="l-info">${escapeHtml(t('Multi-langue:', 'Multi-lang  :'))}</span> ${multilang ? t('oui', 'yes') : t('non', 'no')}`);
    print(`  <span class="l-info">${escapeHtml(t('Delai serre :', 'Rush        :'))}</span> ${rush ? t('oui (+30%)', 'yes (+30%)') : t('non', 'no')}`);
    print('');
    const fmt = (n: number) => n.toLocaleString(lang === 'fr' ? 'fr-FR' : 'en-US');
    print(`  <span class="l-accent">${escapeHtml(t('Estimation  :', 'Estimate    :'))}</span> <span class="l-ok">${fmt(min)} EUR -- ${fmt(max)} EUR</span>`);
    print(`  <span class="l-accent">${escapeHtml(t('Delai       :', 'Timeline    :'))}</span> ${weeks} ${escapeHtml(t('semaines', 'weeks'))}`);
    print('');
    print(`<span class="l-info">${escapeHtml(t('Estimation indicative -- tape "contact" pour discuter.', 'Indicative -- type "contact" to discuss.'))}</span>`);
    print('');

    mode = { kind: 'idle' };
    prompt!.textContent = 'albert@portfolio:~$';
  }

  // ── Tab autocomplete ──────────────────────────────────────────────────
  function autocomplete(value: string): string {
    const trimmed = value.trimStart();
    const parts = trimmed.split(/\s+/);
    if (parts.length === 1) {
      const matches = Object.keys(commands).filter(k => k.startsWith(parts[0] ?? ''));
      if (matches.length === 1) return (matches[0] ?? '') + ' ';
      if (matches.length > 1) {
        print(`<span class="l-info">${matches.join('  ')}</span>`);
        return value;
      }
      return value;
    }
    if (parts[0] === 'cat') {
      const last = parts[parts.length - 1] ?? '';
      const fileMatches = Object.keys(fs).filter(f => f.startsWith(last));
      if (fileMatches.length === 1) {
        parts[parts.length - 1] = fileMatches[0] ?? '';
        return parts.join(' ');
      }
      if (fileMatches.length > 1) {
        print(`<span class="l-info">${fileMatches.join('  ')}</span>`);
      }
    }
    return value;
  }

  // ── Input handling ────────────────────────────────────────────────────
  function handleSubmit(raw: string): void {
    const value = raw.trim();
    printPromptCmd(raw);

    if (mode.kind === 'quote') {
      if (value.toLowerCase() === 'cancel') {
        print(`<span class="l-warn">${escapeHtml(t('Devis annule.', 'Quote cancelled.'))}</span>`);
        mode = { kind: 'idle' };
        prompt!.textContent = 'albert@portfolio:~$';
        return;
      }
      const q = QUOTE_QUESTIONS[mode.step];
      if (!q) return finishQuote();
      if (!q.validate(value)) {
        print(`<span class="l-err">${escapeHtml(t('Reponse invalide. Reessaie.', 'Invalid answer. Try again.'))}</span>`);
        askQuoteStep();
        return;
      }
      q.assign(mode.data, value);
      mode.step += 1;
      askQuoteStep();
      return;
    }

    if (!value) return;
    history.push(value);
    histIdx = history.length;

    const [name, ...args] = value.split(/\s+/);
    const cmd = (name ?? '').toLowerCase();
    if (!cmd) return;

    const fn = commands[cmd];
    if (!fn) {
      print(`<span class="l-err">${escapeHtml(t(`Commande inconnue : ${cmd}`, `Unknown command: ${cmd}`))}</span>`);
      print(`<span class="l-info">${escapeHtml(t('Tape "help" pour la liste.', 'Type "help" for the list.'))}</span>`);
      return;
    }
    void fn(args);
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const v = input.value;
    input.value = '';
    handleSubmit(v);
  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowUp') {
      if (history.length === 0) return;
      e.preventDefault();
      histIdx = Math.max(0, histIdx - 1);
      input.value = history[histIdx] ?? '';
      requestAnimationFrame(() => input.setSelectionRange(input.value.length, input.value.length));
    } else if (e.key === 'ArrowDown') {
      if (history.length === 0) return;
      e.preventDefault();
      histIdx = Math.min(history.length, histIdx + 1);
      input.value = history[histIdx] ?? '';
    } else if (e.key === 'Tab') {
      e.preventDefault();
      input.value = autocomplete(input.value);
    } else if (e.key === 'l' && (e.ctrlKey || e.metaKey)) {
      e.preventDefault();
      clearOutput();
    } else if (e.key === 'c' && e.ctrlKey) {
      if (mode.kind === 'quote') {
        e.preventDefault();
        print(`<span class="l-warn">^C -- ${escapeHtml(t('annule', 'cancelled'))}</span>`);
        mode = { kind: 'idle' };
        prompt!.textContent = 'albert@portfolio:~$';
        input.value = '';
      } else if (input.value) {
        e.preventDefault();
        printPromptCmd(input.value + '^C');
        input.value = '';
      }
    }
  });

  // Click anywhere in terminal → focus input
  root.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('.l-link')) return;
    input.focus();
  });

  // Show boot sequence when window opens for the first time
  let booted = false;
  function bootIfNeeded(): void {
    if (booted) return;
    booted = true;
    showBoot();
  }

  // Detect when terminal window is opened (its container goes from closed → open)
  const winEl = document.getElementById('window-terminal');
  if (winEl) {
    const observer = new MutationObserver(() => {
      if (!winEl.classList.contains('window--closed') && !winEl.classList.contains('window--minimized')) {
        bootIfNeeded();
        setTimeout(() => input.focus(), 80);
      }
    });
    observer.observe(winEl, { attributes: true, attributeFilter: ['class'] });
  }

  // Boot immediately if window already visible
  if (winEl && !winEl.classList.contains('window--closed')) bootIfNeeded();
})();
</script>
