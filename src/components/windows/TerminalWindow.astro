---
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="term" data-lang={lang} role="region" aria-label={lang === 'fr' ? 'Terminal Albert.exe' : 'Albert.exe terminal'}>
  <div class="term__output" id="term-output" aria-live="polite" aria-atomic="false"></div>
  <form class="term__input-line" id="term-form" autocomplete="off">
    <span class="term__prompt" id="term-prompt">albert@portfolio:~$</span>
    <input
      class="term__input"
      id="term-input"
      type="text"
      spellcheck="false"
      autocomplete="off"
      autocapitalize="off"
      aria-label={lang === 'fr' ? 'Ligne de commande' : 'Command line'}
    />
    <span class="term__cursor" aria-hidden="true">▊</span>
  </form>
</div>

<style>
.term {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #050409;
  color: #4ade80;
  font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', 'Courier New', Courier, monospace;
  font-size: 0.8125rem;
  line-height: 1.55;
  overflow: hidden;
  border-radius: 0.25rem;
  position: relative;
  cursor: text;
}

/* CRT scanline effect (subtle) */
.term::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    rgba(0, 0, 0, 0.15) 0px,
    rgba(0, 0, 0, 0.15) 1px,
    transparent 1px,
    transparent 3px
  );
  opacity: 0.4;
  z-index: 1;
}

@media (prefers-reduced-motion: reduce) {
  .term::before { display: none; }
}

.term__output {
  flex: 1;
  overflow-y: auto;
  padding: 0.875rem 1rem 0.5rem;
  white-space: pre-wrap;
  word-break: break-word;
  position: relative;
  z-index: 2;
  scrollbar-width: thin;
  scrollbar-color: rgba(74, 222, 128, 0.3) transparent;
}

.term__output::-webkit-scrollbar { width: 6px; }
.term__output::-webkit-scrollbar-track { background: transparent; }
.term__output::-webkit-scrollbar-thumb { background: rgba(74, 222, 128, 0.3); border-radius: 3px; }

.term__input-line {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem 0.875rem;
  position: relative;
  z-index: 2;
  margin: 0;
}

.term__prompt {
  color: #4ade80;
  font-weight: 700;
  flex-shrink: 0;
  text-shadow: 0 0 8px rgba(74, 222, 128, 0.4);
}

.term__input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: #FAF5FF;
  font-family: inherit;
  font-size: inherit;
  caret-color: transparent;
  padding: 0;
  min-width: 0;
}

.term__cursor {
  color: #4ade80;
  font-weight: 700;
  margin-left: -0.4rem;
  pointer-events: none;
  animation: term-blink 1s step-end infinite;
  text-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
}

@keyframes term-blink {
  0%, 50%   { opacity: 1; }
  50.01%, 100% { opacity: 0; }
}

@media (prefers-reduced-motion: reduce) {
  .term__cursor { animation: none; }
}

/* Output line variants */
.term__output :global(.l-prompt)   { color: #4ade80; font-weight: 700; }
.term__output :global(.l-cmd)      { color: #FAF5FF; }
.term__output :global(.l-info)     { color: #94a3b8; }
.term__output :global(.l-ok)       { color: #4ade80; }
.term__output :global(.l-warn)     { color: #F59E0B; }
.term__output :global(.l-err)      { color: #ef4444; }
.term__output :global(.l-accent)   { color: #A78BFA; }
.term__output :global(.l-link)     {
  color: #60A5FA;
  text-decoration: underline;
  cursor: pointer;
}
.term__output :global(.l-link:hover) { color: #93C5FD; }
.term__output :global(.banner)     {
  /* Police robuste pour l'ASCII art — compatibilite Chrome/Firefox */
  font-family: 'Courier New', Courier, 'Liberation Mono', 'DejaVu Sans Mono', monospace;
  color: #4ade80;
  text-shadow: 0 0 12px rgba(74, 222, 128, 0.45);
  display: block;
  white-space: pre;
  line-height: 1.4;
}
.term__output :global(.kbd)        {
  background: rgba(167, 139, 250, 0.15);
  border: 1px solid rgba(167, 139, 250, 0.4);
  border-radius: 0.25rem;
  padding: 0.05rem 0.35rem;
  font-size: 0.7rem;
  color: #C4B5FD;
}

/* Konami flash effect */
.term.konami { animation: term-konami 0.6s ease; }

@keyframes term-konami {
  0%, 100% { filter: hue-rotate(0deg); }
  50%      { filter: hue-rotate(180deg) saturate(2); }
}

@media (max-width: 640px) {
  .term { font-size: 0.75rem; }
  .term__output { padding: 0.625rem 0.75rem 0.4rem; }
  .term__input-line { padding: 0.4rem 0.75rem 0.625rem; }
}
</style>

<script>
import { open as openWindow, close as closeWindow } from '../../utils/window-manager';

(function () {
  const root = document.querySelector<HTMLElement>('.term');
  if (!root) return;
  const output = document.getElementById('term-output') as HTMLDivElement | null;
  const input  = document.getElementById('term-input') as HTMLInputElement | null;
  const form   = document.getElementById('term-form') as HTMLFormElement | null;
  const prompt = document.getElementById('term-prompt') as HTMLSpanElement | null;
  if (!output || !input || !form || !prompt) return;

  const lang = (root.dataset['lang'] === 'en' ? 'en' : 'fr') as 'fr' | 'en';
  const t = (fr: string, en: string): string => (lang === 'fr' ? fr : en);

  const history: string[] = [];
  let histIdx = -1;

  // ── State machine for multi-step commands (quote) ─────────────────────
  type Mode = { kind: 'idle' } | {
    kind: 'quote';
    step: number;
    data: Partial<{ type: string; pages: number; multilang: boolean; rush: boolean }>;
  };
  let mode: Mode = { kind: 'idle' };

  // ── Output helpers ────────────────────────────────────────────────────
  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c] ?? c));
  }

  function print(html: string, cls = ''): void {
    const div = document.createElement('div');
    if (cls) div.className = cls;
    div.innerHTML = html;
    output!.appendChild(div);
    output!.scrollTop = output!.scrollHeight;
  }

  function printLine(text: string, cls = ''): void {
    print(escapeHtml(text), cls);
  }

  function printPromptCmd(cmd: string): void {
    print(`<span class="l-prompt">${prompt!.textContent}</span> <span class="l-cmd">${escapeHtml(cmd)}</span>`);
  }

  function clearOutput(): void {
    output!.innerHTML = '';
  }

  // ── ASCII Banner — pur ASCII, compatible Chrome/Firefox ──────────────
  const BANNER = `+------------------------------------------------------+
|                                                      |
|   ###    ##      ######   #######  ######  #######   |
|  ## ##   ##      ##   ##  ##       ##   ##   ##      |
| ##   ##  ##      ##   ##  ##       ##   ##   ##      |
| #######  ##      ######   #####    ######    ##      |
| ##   ##  ##      ##  ##   ##       ##  ##    ##      |
| ##   ##  #####   ######   #######  ##   ##   ##      |
|                                                      |
|        .exe v2026  --  Mulhouse, FR                  |
+------------------------------------------------------+`;

  function showBanner(): void {
    print(`<span class="banner">${escapeHtml(BANNER)}</span>`);
