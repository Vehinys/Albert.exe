---
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

interface TimelineItem {
  hash: string;
  period: string;
  title: Record<'fr' | 'en', string>;
  company: string;
  location: string;
  description: Record<'fr' | 'en', string>;
  tags: string[];
  current?: boolean;
}

const experiences: TimelineItem[] = [
  {
    hash: 'a1b2c3',
    period: '2026',
    title: { fr: 'Refonte site WordPress — Stage CDUI', en: 'WordPress Redesign — UI Designer Intern' },
    company: 'NAPOCOM',
    location: 'Remote/France',
    description: {
      fr: "Refonte complète du site web de l'agence. Optimisation UX/UI, intégration de maquettes, et configuration avancée de WordPress.",
      en: 'Complete agency website redesign. UI/UX optimization, mockup integration, and advanced WordPress configuration.',
    },
    tags: ['WordPress', 'Elementor', 'CSS', 'UX/UI'],
    current: true,
  },
  {
    hash: 'd4e5f6',
    period: '2023 — 2024',
    title: { fr: 'Vendeur Polyvalent (CDI)', en: 'Multiskilled Salesperson (CDI)' },
    company: 'BLACKSTORE France',
    location: 'Mulhouse',
    description: {
      fr: 'Accueil et conseil client personnalisé. Gestion complète de la caisse, des stocks, inventaires et merchandising.',
      en: 'Personalized customer advice. Full management of till, stock, inventory and merchandising.',
    },
    tags: ['Vente', 'Conseil', 'Merchandising', 'Gestion'],
  },
  {
    hash: 'g7h8i9',
    period: '2022',
    title: { fr: 'Création de maquette — Stage', en: 'Mockup Creation — Intern' },
    company: 'E-NAUMAD',
    location: 'France',
    description: {
      fr: 'Stagiaire Frontend, personnalisation avancée de sites WordPress. Création de visuels et maquettes (Photoshop, Figma).',
      en: 'Frontend intern, advanced WordPress customization. Creation of visuals and mockups (Photoshop, Figma).',
    },
    tags: ['WordPress', 'PHP', 'CSS', 'Photoshop', 'Figma'],
  },
  {
    hash: 'j1k2l3',
    period: '2015 — 2021',
    title: { fr: 'Vendeur Polyvalent (CDI)', en: 'Multiskilled Salesperson (CDI)' },
    company: 'IKEA',
    location: 'Mulhouse',
    description: {
      fr: "6 ans d'expérience en relation client, gestion de stock, merchandising et logistique (CACES).",
      en: '6 years of experience in customer relations, stock management, merchandising and logistics (CACES).',
    },
    tags: ['Relation Client', 'Logistique', 'Soft-skills'],
  },
];

const education: TimelineItem[] = [
  {
    hash: 'm4n5o6',
    period: '2025 — 2026',
    title: { fr: 'Concepteur Designer UI (Niveau 6)', en: 'UI Designer Conceptor (Level 6)' },
    company: 'GRETA Alsace Sud',
    location: 'Mulhouse',
    description: {
      fr: "Niveau : En cours. Conception pour WordPress & UI/UX Design. Suite Adobe. Intégration HTML5/CSS3 et Framework Symfony.",
      en: 'Level: In progress. Design for WordPress & UI/UX. Adobe Suite. HTML5/CSS3 and Symfony Framework.',
    },
    tags: ['Adobe Suite', 'Symfony', 'WordPress'],
    current: true,
  },
  {
    hash: 'p7q8r9',
    period: '2024',
    title: { fr: 'Développeur Web & Mobile (Niveau 5)', en: 'Web & Mobile Developer (Level 5)' },
    company: 'Elan Formation',
    location: 'Mulhouse',
    description: {
      fr: 'Niveau : Diplôme Acquis. Maquettage Figma, JS, PHP, Symfony, SQL/NoSQL. Gestion de projet Agile.',
      en: 'Level: Degree Acquired. Figma wireframing, JS, PHP, Symfony, SQL/NoSQL. Agile project management.',
    },
    tags: ['JS/PHP', 'Symfony', 'SQL', 'Agile'],
  },
  {
    hash: 's1t2u3',
    period: '2022 — 2023',
    title: { fr: 'Infographiste Metteur en Page (Niveau 4)', en: 'Graphic Designer Page Setter (Level 4)' },
    company: 'GRETA Sud Alsace',
    location: 'Mulhouse',
    description: {
      fr: "Niveau : Diplôme Acquis. Analyse des besoins, propositions graphiques, InDesign, Photoshop, Illustrator.",
      en: 'Level: Degree Acquired. Needs analysis, graphic proposals, InDesign, Photoshop, Illustrator.',
    },
    tags: ['InDesign', 'Photoshop', 'Illustrator'],
  },
  {
    hash: 'v4w5x6',
    period: '2006',
    title: { fr: 'Titre Pro. Vendeur Conseil (Niveau 4)', en: 'Sales Advisor Certificate (Level 4)' },
    company: 'CEFA Saint-Anne',
    location: 'Belgique',
    description: {
      fr: 'Niveau : Diplôme Acquis. Techniques de vente, conseil client, merchandising et gestion commerciale.',
      en: 'Level: Degree Acquired. Sales techniques, customer advice, merchandising and commercial management.',
    },
    tags: ['Vente', 'Conseil', 'Merchandising'],
  },
];

const labels = {
  fr: {
    tabExp: 'Expériences',
    tabEdu: 'Formation',
    branch: '⎇ main | albert-lecomte/career',
    current: 'Actuel',
    headBadge: 'HEAD → current',
    stageLabel: 'Stage',
    diplomaLabel: 'Diplôme',
    inProgressLabel: 'En cours',
  },
  en: {
    tabExp: 'Experience',
    tabEdu: 'Education',
    branch: '⎇ main | albert-lecomte/career',
    current: 'Current',
    headBadge: 'HEAD → current',
    stageLabel: 'Intern',
    diplomaLabel: 'Degree',
    inProgressLabel: 'In Progress',
  },
} as const;

const l = labels[lang];
---

<div class="gitlog-win" role="region" aria-label={lang === 'fr' ? 'Historique de carrière' : 'Career history'}>

  <!-- Toolbar -->
  <div class="gitlog-toolbar">
    <span class="gitlog-branch" aria-label={lang === 'fr' ? 'Branche Git' : 'Git branch'}>
      {l.branch}
    </span>
  </div>

  <!-- Tabs -->
  <div class="gitlog-tabs" role="tablist" aria-label={lang === 'fr' ? 'Onglets' : 'Tabs'}>
    <button
      class="gitlog-tab gitlog-tab--active"
      role="tab"
      id="gitlog-tab-exp"
      aria-selected="true"
      aria-controls="gitlog-panel-exp"
      type="button"
    >
      <span aria-hidden="true">💼</span>
      {l.tabExp}
    </button>
    <button
      class="gitlog-tab"
      role="tab"
      id="gitlog-tab-edu"
      aria-selected="false"
      aria-controls="gitlog-panel-edu"
      type="button"
    >
      <span aria-hidden="true">🎓</span>
      {l.tabEdu}
    </button>
  </div>

  <!-- Panel: Experiences -->
  <div
    class="gitlog-panel"
    id="gitlog-panel-exp"
    role="tabpanel"
    aria-labelledby="gitlog-tab-exp"
  >
    <ol class="gitlog-list" aria-label={lang === 'fr' ? 'Expériences professionnelles' : 'Professional experience'}>
      {experiences.map((item, i) => (
        <li class="gitlog-commit">
          <div class="gitlog-commit__graph" aria-hidden="true">
            <span class={`gitlog-dot ${item.current ? 'gitlog-dot--current' : 'gitlog-dot--exp'}`}></span>
            {i < experiences.length - 1 && <span class="gitlog-line gitlog-line--exp"></span>}
          </div>
          <div class="gitlog-commit__body">
            <div class="gitlog-commit__meta">
              <code class="gitlog-hash">{item.hash}</code>
              {item.current && (
                <span class="gitlog-head-badge" aria-label={lang === 'fr' ? 'Poste actuel' : 'Current position'}>
                  {l.headBadge}
                </span>
              )}
              <time class="gitlog-period">{item.period}</time>
            </div>
            <h3 class="gitlog-commit__title">{item.title[lang]}</h3>
            <p class="gitlog-commit__author">
              <span aria-hidden="true">⎇</span>
              {item.company}
              <span class="gitlog-sep" aria-hidden="true">—</span>
              <span class="gitlog-location">{item.location}</span>
            </p>
            <p class="gitlog-commit__message">"{item.description[lang]}"</p>
            <ul class="gitlog-tags" role="list" aria-label={lang === 'fr' ? 'Technologies' : 'Technologies'}>
              {item.tags.map(tag => <li class="gitlog-tag">{tag}</li>)}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <!-- Panel: Education -->
  <div
    class="gitlog-panel gitlog-panel--hidden"
    id="gitlog-panel-edu"
    role="tabpanel"
    aria-labelledby="gitlog-tab-edu"
    tabindex="0"
  >
    <ol class="gitlog-list" aria-label={lang === 'fr' ? 'Formation académique' : 'Academic background'}>
      {education.map((item, i) => (
        <li class="gitlog-commit">
          <div class="gitlog-commit__graph" aria-hidden="true">
            <span class={`gitlog-dot ${item.current ? 'gitlog-dot--edu-current' : 'gitlog-dot--edu'}`}></span>
            {i < education.length - 1 && <span class="gitlog-line gitlog-line--edu"></span>}
          </div>
          <div class="gitlog-commit__body">
            <div class="gitlog-commit__meta">
              <code class="gitlog-hash gitlog-hash--edu">{item.hash}</code>
              {item.current && (
                <span class="gitlog-head-badge gitlog-head-badge--edu">
                  {l.inProgressLabel}
                </span>
              )}
              <time class="gitlog-period">{item.period}</time>
            </div>
            <h3 class="gitlog-commit__title">{item.title[lang]}</h3>
            <p class="gitlog-commit__author gitlog-commit__author--edu">
              <span aria-hidden="true">🎓</span>
              {item.company}
              <span class="gitlog-sep" aria-hidden="true">—</span>
              <span class="gitlog-location">{item.location}</span>
            </p>
            <p class="gitlog-commit__message">"{item.description[lang]}"</p>
            <ul class="gitlog-tags" role="list" aria-label={lang === 'fr' ? 'Technologies' : 'Technologies'}>
              {item.tags.map(tag => <li class="gitlog-tag gitlog-tag--edu">{tag}</li>)}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>

</div>

<style>
/* ── Root ──────────────────────────────────────────────────────── */
.gitlog-win {
  display: flex;
  flex-direction: column;
  background: #06050F;
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: 0.5rem;
  overflow: hidden;
  font-size: 0.8125rem;
}

/* ── Toolbar ───────────────────────────────────────────────────── */
.gitlog-toolbar {
  padding: 0.4rem 0.875rem;
  background: rgba(139, 92, 246, 0.08);
  border-bottom: 1px solid rgba(139, 92, 246, 0.18);
  flex-shrink: 0;
}

.gitlog-branch {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size: 0.7rem;
  color: #4ade80;
  letter-spacing: 0.03em;
}

/* ── Tabs ──────────────────────────────────────────────────────── */
.gitlog-tabs {
  display: flex;
  background: rgba(0, 0, 0, 0.2);
  border-bottom: 1px solid rgba(139, 92, 246, 0.15);
  flex-shrink: 0;
}

.gitlog-tab {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 1rem;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: #94A3B8;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: color 0.15s ease, border-color 0.15s ease;
}

.gitlog-tab:hover {
  color: #C4B5FD;
}

.gitlog-tab--active {
  color: #A78BFA;
  border-bottom-color: #8B5CF6;
}

.gitlog-tab:focus-visible {
  outline: 2px solid #F59E0B;
  outline-offset: -2px;
}

/* ── Panels ────────────────────────────────────────────────────── */
.gitlog-panel {
  overflow-y: auto;
  padding: 0.875rem 0.875rem 0.875rem 0.75rem;
}

.gitlog-panel--hidden {
  display: none;
}

/* ── Commit list ───────────────────────────────────────────────── */
.gitlog-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.gitlog-commit {
  display: grid;
  grid-template-columns: 1.5rem 1fr;
  gap: 0.75rem;
  padding-bottom: 0;
}

/* ── Graph column ──────────────────────────────────────────────── */
.gitlog-commit__graph {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 0.875rem;
  flex-shrink: 0;
}

.gitlog-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
  z-index: 1;
  border: 2px solid;
}

.gitlog-dot--exp {
  border-color: #8B5CF6;
  background: #06050F;
}

.gitlog-dot--current {
  border-color: #F59E0B;
  background: #F59E0B;
  box-shadow: 0 0 8px rgba(245, 158, 11, 0.7), 0 0 20px rgba(245, 158, 11, 0.3);
}

.gitlog-dot--edu {
  border-color: #A78BFA;
  background: #06050F;
}

.gitlog-dot--edu-current {
  border-color: #A78BFA;
  background: #A78BFA;
  box-shadow: 0 0 8px rgba(167, 139, 250, 0.6);
}

.gitlog-line {
  width: 2px;
  flex: 1;
  min-height: 1rem;
  margin-top: 3px;
}

.gitlog-line--exp {
  background: linear-gradient(to bottom, rgba(139, 92, 246, 0.5), rgba(139, 92, 246, 0.1));
}

.gitlog-line--edu {
  background: linear-gradient(to bottom, rgba(167, 139, 250, 0.5), rgba(167, 139, 250, 0.1));
}

/* ── Commit body ───────────────────────────────────────────────── */
.gitlog-commit__body {
  padding: 0.75rem 0 1rem;
  border-bottom: 1px solid rgba(139, 92, 246, 0.08);
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.gitlog-list li:last-child .gitlog-commit__body {
  border-bottom: none;
}

.gitlog-commit__meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.gitlog-hash {
  font-family: 'Consolas', 'Courier New', monospace;
  font-size: 0.7rem;
  color: #F59E0B;
  background: rgba(245, 158, 11, 0.08);
  padding: 0.1rem 0.35rem;
  border-radius: 0.25rem;
  letter-spacing: 0.04em;
}

.gitlog-hash--edu {
  color: #A78BFA;
  background: rgba(167, 139, 250, 0.08);
}

.gitlog-head-badge {
  font-size: 0.65rem;
  font-weight: 700;
  background: rgba(245, 158, 11, 0.12);
  border: 1px solid rgba(245, 158, 11, 0.35);
  color: #F59E0B;
  padding: 0.1rem 0.4rem;
  border-radius: 0.25rem;
  font-family: 'Consolas', 'Courier New', monospace;
  letter-spacing: 0.02em;
}

.gitlog-head-badge--edu {
  background: rgba(167, 139, 250, 0.12);
  border-color: rgba(167, 139, 250, 0.35);
  color: #A78BFA;
}

.gitlog-period {
  font-size: 0.7rem;
  color: #475569;
  margin-left: auto;
  font-family: 'Consolas', 'Courier New', monospace;
}

.gitlog-commit__title {
  font-size: 0.9rem;
  font-weight: 700;
  color: #FAF5FF;
  margin: 0;
  line-height: 1.3;
}

.gitlog-commit__author {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.75rem;
  color: #8B5CF6;
  margin: 0;
  font-weight: 500;
}

.gitlog-commit__author--edu {
  color: #A78BFA;
}

.gitlog-sep {
  color: rgba(139, 92, 246, 0.3);
}

.gitlog-location {
  color: #94A3B8;
}

.gitlog-commit__message {
  font-size: 0.8rem;
  color: #C4B5FD;
  line-height: 1.65;
  margin: 0;
  font-style: italic;
  padding-left: 0.5rem;
  border-left: 2px solid rgba(139, 92, 246, 0.2);
}

/* ── Tags ──────────────────────────────────────────────────────── */
.gitlog-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  list-style: none;
  padding: 0;
  margin: 0.25rem 0 0;
}

.gitlog-tag {
  padding: 0.1rem 0.45rem;
  border-radius: 0.25rem;
  font-size: 0.65rem;
  font-weight: 600;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.2);
  color: #A78BFA;
  font-family: 'Consolas', 'Courier New', monospace;
}

.gitlog-tag--edu {
  background: rgba(167, 139, 250, 0.08);
  border-color: rgba(167, 139, 250, 0.2);
  color: #C4B5FD;
}
</style>

<script>
(function () {
  const win = document.querySelector<HTMLElement>('.gitlog-win');
  if (!win) return;

  const tabs   = win.querySelectorAll<HTMLButtonElement>('.gitlog-tab');
  const panels = win.querySelectorAll<HTMLElement>('.gitlog-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetId = tab.getAttribute('aria-controls');
      if (!targetId) return;

      tabs.forEach(t => {
        t.classList.remove('gitlog-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.add('gitlog-panel--hidden'));

      tab.classList.add('gitlog-tab--active');
      tab.setAttribute('aria-selected', 'true');

      const target = win.querySelector<HTMLElement>(`#${targetId}`);
      target?.classList.remove('gitlog-panel--hidden');
    });
  });
})();
</script>
