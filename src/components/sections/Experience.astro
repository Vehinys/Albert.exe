---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface TimelineItem {
  period: string;
  title: Record<'fr' | 'en', string>;
  company: string;
  location: string;
  description: Record<'fr' | 'en', string>;
  tags: string[];
  current?: boolean;
}

const experiences: TimelineItem[] = [
  {
    period: '2026 (2 mois)',
    title: { fr: 'Refonte site WordPress — Stage CDUI', en: 'WordPress Redesign — UI Designer Intern' },
    company: 'NAPOCOM',
    location: 'Remote/France',
    description: {
      fr: 'Refonte complète du site web de l\'agence. Optimisation UX/UI, intégration de maquettes, et configuration avancée de WordPress.',
      en: 'Complete agency website redesign. UI/UX optimization, mockup integration, and advanced WordPress configuration.',
    },
    tags: ['WordPress', 'Elementor', 'CSS', 'UX/UI'],
    current: true,
  },
  {
    period: '2023 — 2024',
    title: { fr: 'Vendeur Polyvalent (CDI)', en: 'Multiskilled Salesperson (CDI)' },
    company: 'BLACKSTORE France',
    location: 'Mulhouse',
    description: {
      fr: 'Accueil et conseil client personnalisé. Gestion complète de la caisse, des stocks, inventaires et merchandising. Responsabilité des ouvertures et fermetures.',
      en: 'Personalized customer advice. Full management of till, stock, inventory and merchandising. Responsible for opening and closing.',
    },
    tags: ['Vente', 'Conseil', 'Merchandising', 'Gestion'],
  },
  {
    period: '2022 (Stage)',
    title: { fr: 'Création de maquette — Stage', en: 'Mockup Creation — Intern' },
    company: 'E-NAUMAD',
    location: 'France',
    description: {
      fr: 'Stagiaire Frontend, personnalisation avancée de sites WordPress. Création de visuels et maquettes (Photoshop, Figma).',
      en: 'Frontend intern, advanced WordPress customization. Creation of visuals and mockups (Photoshop, Figma).',
    },
    tags: ['WordPress', 'PHP', 'CSS', 'Photoshop', 'Figma'],
  },
  {
    period: '2015 — 2021',
    title: { fr: 'Vendeur Polyvalent (CDI)', en: 'Multiskilled Salesperson (CDI)' },
    company: 'IKEA',
    location: 'Mulhouse',
    description: {
      fr: '6 ans d\'expérience en relation client, gestion de stock, merchandising et logistique (CACES). Travail d\'équipe, rigueur, gestion du stress.',
      en: '6 years of experience in customer relations, stock management, merchandising and logistics (CACES). Teamwork, rigour, stress management.',
    },
    tags: ['Relation Client', 'Logistique', 'Soft-skills'],
  },
  {
    period: '2024',
    title: { fr: 'Missions Intérim (Caissier)', en: 'Temporary Missions (Cashier)' },
    company: 'Brico Dépôt / Castorama',
    location: 'Mulhouse',
    description: {
      fr: 'Missions ponctuelles de caissier : gestion des encaissements, accueil client, rigueur et efficacité.',
      en: 'Occasional cashier missions: payment management, customer reception, rigour and efficiency.',
    },
    tags: ['Accueil', 'Caisse', 'Rigueur'],
  },
];

const education: TimelineItem[] = [
  {
    period: '2025 — 2026',
    title: { fr: 'Concepteur Designer UI (Niveau 6)', en: 'UI Designer Conceptor (Level 6)' },
    company: 'GRETA Alsace Sud',
    location: 'Mulhouse',
    description: {
      fr: 'Niveau : En cours. Conception pour WordPress & UI/UX Design. Suite Adobe (Photoshop, Illustrator, XD). Intégration HTML5/CSS3 et Framework Symfony.',
      en: 'Level: In progress. Design for WordPress & UI/UX. Adobe Suite (Photoshop, Illustrator, XD). HTML5/CSS3 and Symfony Framework.',
    },
    tags: ['Adobe Suite', 'Symfony', 'WordPress'],
  },
  {
    period: '2024',
    title: { fr: 'Développeur Web & Mobile (Niveau 5)', en: 'Web & Mobile Developer (Level 5)' },
    company: 'Elan Formation',
    location: 'Mulhouse',
    description: {
      fr: 'Niveau : Diplôme Acquis. Maquettage Figma, JS, PHP, Symfony, SQL/NoSQL. Gestion de projet Agile, GitHub, Sécurité Web.',
      en: 'Level: Degree Acquired. Figma wireframing, JS, PHP, Symfony, SQL/NoSQL. Agile project management, GitHub, Web Security.',
    },
    tags: ['JS/PHP', 'Symfony', 'SQL', 'Agile'],
  },
  {
    period: '2022 — 2023',
    title: { fr: 'Infographiste Metteur en Page (Niveau 4)', en: 'Graphic Designer Page Setter (Level 4)' },
    company: 'GRETA Sud Alsace',
    location: 'Mulhouse',
    description: {
      fr: 'Niveau : Diplôme Acquis. Analyse des besoins, propositions graphiques, InDesign, Photoshop, Illustrator.',
      en: 'Level: Degree Acquired. Needs analysis, graphic proposals, InDesign, Photoshop, Illustrator.',
    },
    tags: ['InDesign', 'Photoshop', 'Illustrator'],
  },
  {
    period: '2021 — 2022',
    title: { fr: 'Découverte Métiers du Numérique', en: 'Introduction to Digital Professions' },
    company: 'Elan Formation',
    location: 'Mulhouse',
    description: {
      fr: 'Niveau : Non diplômant. Initiation HTML/CSS/JS/PHP. Photoshop, Illustrator et Figma.',
      en: 'Level: Non-degree. Introduction to HTML/CSS/JS/PHP. Photoshop, Illustrator and Figma.',
    },
    tags: ['Initiation', 'Design', 'Web'],
  },
];
---

<section id="experience" class="experience section-padding" aria-labelledby="experience-title">
  <div class="experience__container">
    <div class="experience__header">
      <p class="section-label">{t('experience.title')}</p>
      <h2 id="experience-title" class="section-title">{t('experience.subtitle')}</h2>
    </div>

    <div class="timeline" role="list" aria-label={lang === 'fr' ? 'Expériences professionnelles' : 'Work experience'}>
      {experiences.map((item, i) => (
        <article class="timeline__item" role="listitem">
          <div class="timeline__marker" aria-hidden="true">
            <div class={`timeline__dot ${item.current ? 'timeline__dot--current' : ''}`}></div>
            {i < experiences.length - 1 && <div class="timeline__line"></div>}
          </div>

          <div class="timeline__content glass-card">
            <div class="timeline__meta">
              <time class="timeline__period">{item.period}</time>
              {item.current && (
                <span class="timeline__current-badge" aria-label={lang === 'fr' ? 'Poste actuel' : 'Current position'}>
                  {lang === 'fr' ? 'Actuel' : 'Current'}
                </span>
              )}
            </div>

            <h3 class="timeline__title">{item.title[lang]}</h3>
            <p class="timeline__company">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              {item.company} — {item.location}
            </p>

            <p class="timeline__desc">{item.description[lang]}</p>

            <ul class="timeline__tags" role="list" aria-label={lang === 'fr' ? 'Technologies' : 'Technologies'}>
              {item.tags.map(tag => <li class="tag">{tag}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <!-- Formation -->
    <div class="experience__header" style="margin-top:4rem">
      <p class="section-label">{t('education.title')}</p>
      <h2 id="education-title" class="section-title">{t('education.subtitle')}</h2>
    </div>

    <div class="timeline" role="list" aria-label={lang === 'fr' ? 'Formation académique' : 'Academic background'} aria-labelledby="education-title">
      {education.map((item, i) => (
        <article class="timeline__item" role="listitem">
          <div class="timeline__marker" aria-hidden="true">
            <div class="timeline__dot timeline__dot--edu"></div>
            {i < education.length - 1 && <div class="timeline__line"></div>}
          </div>

          <div class="timeline__content glass-card">
            <time class="timeline__period">{item.period}</time>
            <h3 class="timeline__title">{item.title[lang]}</h3>
            <p class="timeline__company">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              {item.company} — {item.location}
            </p>
            <p class="timeline__desc">{item.description[lang]}</p>
            <ul class="timeline__tags" role="list">
              {item.tags.map(tag => <li class="tag">{tag}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.experience__container {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.experience__header {
  text-align: center;
}

.section-label {
  font-size: 0.875rem;
  font-weight: 600;
  color: #3b82f6;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.75rem;
}

.section-title {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline__item {
  display: grid;
  grid-template-columns: 2rem 1fr;
  gap: 1.25rem;
  padding-bottom: 1.5rem;
}

.timeline__marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 1.5rem;
}

.timeline__dot {
  width: 0.875rem;
  height: 0.875rem;
  border-radius: 50%;
  border: 2px solid #3b82f6;
  background: var(--color-bg);
  flex-shrink: 0;
  z-index: 1;
}

.timeline__dot--current {
  background: #3b82f6;
  box-shadow: 0 0 12px rgba(59,130,246,0.5);
}

.timeline__dot--edu {
  border-color: #0ea5e9;
}

.timeline__line {
  width: 2px;
  flex: 1;
  background: var(--glass-border);
  margin-top: 4px;
}

.timeline__content {
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.timeline__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.timeline__period {
  font-size: 0.8rem;
  font-weight: 600;
  color: #3b82f6;
  letter-spacing: 0.02em;
}

.timeline__current-badge {
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  background: rgba(34,197,94,0.15);
  border: 1px solid rgba(34,197,94,0.3);
  color: #4ade80;
  text-transform: uppercase;
}

.timeline__title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text);
  margin: 0;
}

.timeline__company {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.85rem;
  color: var(--color-text-subtle);
  margin: 0;
}

.timeline__desc {
  font-size: 0.875rem;
  color: var(--color-text-subtle);
  line-height: 1.7;
  margin: 0;
}

.timeline__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  list-style: none;
  padding: 0;
  margin: 0;
  margin-top: 0.25rem;
}

.tag {
  padding: 0.2rem 0.625rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 600;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  color: var(--color-text-subtle);
}
</style>
